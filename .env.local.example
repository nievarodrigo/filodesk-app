# Supabase — Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago — mercadopago.com.ar → Tu negocio → Credenciales
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Webhook secret para validar firmas de notificaciones de MP
MP_WEBHOOK_SECRET=

# Solo para desarrollo/staging con cuentas de prueba de MP
# Fuerza el email del pagador a una cuenta de test
# MP_TEST_PAYER_EMAIL=test_user_xxxxxxx@testuser.com

# Cloudflare Turnstile — dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# URL del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# GalioPay — Configuración de webhooks y credenciales
GALIOPAY_API_BASE=https://pay.galio.app/api
GALIOPAY_API_KEY=
GALIOPAY_CLIENT_ID=
# CVU y Alias del servidor — NUNCA exponer al cliente
GALIOPAY_CVU=
GALIOPAY_ALIAS=
# Secret para validar webhooks de GalioPay
GALIOPAY_WEBHOOK_SECRET=
